export const getPresetsByGroup = () => {
  const groups: Record<string, ArtboardPreset[]> = {};
  ARTBOARD_PRESETS.forEach(p => {
    if (!groups[p.group]) groups[p.group] = [];
    groups[p.group].push(p);
  });
  return groups;
