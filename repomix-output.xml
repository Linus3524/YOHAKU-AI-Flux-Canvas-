                  className="w-full accent-[#007AFF]"
                />
              </div>
              {/* 即時預覽條 */}
              <div 
                className="w-full h-4 rounded border border-black/10 mt-1"
                style={{ backgroundImage: buildLinearGradientCSS(gradAngle, gradColor1, gradColor2) }}
              />
