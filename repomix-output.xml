                />
              </div>
              <div className="flex flex-col gap-1">
                <div className="flex justify-between">
                  <span className="text-xs text-[#86868B]">角度</span>
                  <span className="text-xs text-[#1D1D1F] font-medium">{gradAngle}°</span>
                </div>
                <input 
                  type="range" 
