import React, { useRef, useEffect, useState, useCallback } from 'react';
import type { DrawingElement, Point } from '../types';

interface DrawingModalProps {
  element: DrawingElement;
  onSave: (elementId: string, dataUrl: string) => void;
  onClose: () => void;
