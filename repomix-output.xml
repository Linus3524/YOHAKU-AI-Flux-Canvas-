  shadowColor?: string;
  shadowBlur?: number;
  glowColor?: string;
  glowBlur?: number;
  
  // Vertical Text Support
  writingMode?: 'horizontal' | 'vertical';
  
  // Curved Text Support
  curveStrength?: number; // -100 to 100
}

export type ShapeType = 'rectangle' | 'circle' | 'triangle' | 'pentagon' | 'hexagon' | 'star' | 'heart' | 'rounded_rect';

